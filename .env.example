# OpenRouter API (AI分析に必須)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Financial Modeling Prep API (企業検索・株価データ)
FMP_API_KEY=your_fmp_api_key_here

# SerpAPI (検索フォールバック)
SERPAPI_API_KEY=your_serpapi_key_here

# NewsAPI (ニュース取得)
NEWSAPI_API_KEY=your_newsapi_key_here

# Firebase (認証・データベース)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# Lemon Squeezy (課金)
LEMON_SQUEEZY_API_KEY=your_lemon_squeezy_api_key_here
LEMON_SQUEEZY_STORE_ID=your_store_id
LEMON_SQUEEZY_VARIANT_ID_MONTHLY=your_monthly_variant_id
LEMON_SQUEEZY_VARIANT_ID_YEARLY=your_yearly_variant_id

# App URL
NEXT_PUBLIC_APP_URL=https://kabu-ana.com

# ===== Market Signals (新規タブ /signals 用) =====
# EIA Open Data API (WTI / Brent / 天然ガス / ガソリン在庫)
# 登録: https://www.eia.gov/opendata/register.php (無料)
EIA_API_KEY=your_eia_api_key_here

# FRED API (VIX / USDインデックス / 米10年金利)
# 登録: https://fred.stlouisfed.org/docs/api/api_key.html (無料)
FRED_API_KEY=your_fred_api_key_here

# Vercel Cron 認証用シークレット
# 生成: openssl rand -hex 32
SIGNALS_CRON_SECRET=your_random_64_char_hex_here
